#!/bin/bash
# gemini-switch — dual OAuth profile switcher for Gemini CLI
# Usage:
#   gemini-switch 1          # switch to profile 1 (jpveigao10)
#   gemini-switch 2          # switch to profile 2 (vgpnk1337)
#   gemini-switch status     # show which profile is active
#   gemini-switch auto       # auto-switch: if current profile hit 429, switch to other

PROFILES_DIR="$HOME/.gemini/oauth-profiles"
CREDS="$HOME/.gemini/oauth_creds.json"
ACCOUNTS="$HOME/.gemini/google_accounts.json"
STATE_FILE="$PROFILES_DIR/active-profile"

# Initialize state file if missing
[ ! -f "$STATE_FILE" ] && echo "1" > "$STATE_FILE"

current() {
  cat "$STATE_FILE"
}

switch_to() {
  local target="$1"
  cp "$PROFILES_DIR/oauth-${target}.json" "$CREDS"
  cp "$PROFILES_DIR/accounts-${target}.json" "$ACCOUNTS"
  echo "$target" > "$STATE_FILE"
  local account=$(python3 -c "import json; print(json.load(open('$ACCOUNTS'))['active'])")
  echo "Switched to profile [$target]: $account"
}

other() {
  local cur=$(current)
  [ "$cur" = "1" ] && echo "2" || echo "1"
}

case "${1:-status}" in
  1|2)
    switch_to "$1"
    ;;
  status)
    local_cur=$(current)
    local_account=$(python3 -c "import json; print(json.load(open('$ACCOUNTS'))['active'])")
    echo "Active: profile [$local_cur] — $local_account"
    echo "[1]: $(python3 -c "import json; print(json.load(open('$PROFILES_DIR/accounts-1.json'))['active'])")"
    echo "[2]: $(python3 -c "import json; print(json.load(open('$PROFILES_DIR/accounts-2.json'))['active'])")"
    ;;
  auto)
    echo "Auto-switching from profile [$(current)] to profile [$(other)]"
    switch_to "$(other)"
    ;;
  *)
    echo "Usage: gemini-switch <1|2|status|auto>" >&2
    exit 1
    ;;
esac
