#!/bin/bash
# xask — minimal routing protocol for cross-model orchestration
# Usage: xask [-d] [-s <scope>] [-r] [--spk] [-e <level>] <model> "<query>" ["<context>"] ["<skill>"]
#
# All dispatches route through `xbreed ask`. Always-on: suppression, approval bypass,
# auth cascade, godspeed forwarding, fast_mode (gpt-5.4). See docs/xask-protocol.md.
#
# Flags: -d (debug) | -s (scope) | -r (rich) | --spk (spark) | -e (effort)
#
# Examples:
#   xask gemini "What patterns exist?"              # clean, godspeed loaded
#   xask -s "src/ask.rs" gemini "Review this"       # scoped clean dispatch
#   xask -r gemini "Explore the codebase"           # full context, dir tree ON
#   xask --spk codex "Probe this hypothesis"        # fast codex-spark, low effort
#   xask -e high codex "Deep review"                # high reasoning effort
#   xask claude "Analyze this" "prior findings"     # claude (no CLI injection)

GEMINI_SETTINGS_FILE="$HOME/.gemini/settings.json"

# Handle flags
DEBUG=false
SCOPE="entire project"
RICH=false
SPARK=false
EFFORT=""
while [[ "$1" == -* ]]; do
  case "$1" in
    --debug  | -d)   DEBUG=true; shift ;;
    --scope  | -s)   SCOPE="$2"; shift 2 ;;
    --rich   | -r)   RICH=true; shift ;;
    --spark  | --spk) SPARK=true; shift ;;
    --effort | -e)   EFFORT="$2"; shift 2 ;;
    --direct)        SPARK=false; shift ;; # deprecated: suppression is always-on, use --effort for reasoning level
    *) shift ;;
  esac
done

MODEL="$1"
QUERY="$2"
CONTEXT="${3:-No prior context.}"
SKILL="${4:-godspeed}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
TEMPLATE_DIR="$SCRIPT_DIR/../templates/dispatch"
TEMPLATE="$TEMPLATE_DIR/${MODEL}.md"

if [ -z "$MODEL" ] || [ -z "$QUERY" ]; then
  echo "Usage: xask [-d|--debug] [-s|--scope <boundary>] [-r|--rich] [--spk|--spark] [-e|--effort <level>] <model> \"<query>\" [\"<context>\"] [\"<skill>\"]" >&2
  exit 1
fi

# Build prompt from template
if [ -f "$TEMPLATE" ]; then
  # Escape & and \ in replacement strings to prevent awk gsub from
  # interpreting & as "matched text" and \ as escape sequences.
  QUERY_SAFE=$(printf '%s' "$QUERY" | sed 's/[&\\]/\\&/g')
  CONTEXT_SAFE=$(printf '%s' "$CONTEXT" | sed 's/[&\\]/\\&/g')
  SCOPE_SAFE=$(printf '%s' "$SCOPE" | sed 's/[&\\]/\\&/g')
  PROMPT=$(awk -v q="$QUERY_SAFE" -v c="$CONTEXT_SAFE" -v s="$SCOPE_SAFE" '{
    gsub(/\{\{QUERY\}\}/, q)
    gsub(/\{\{CONTEXT\}\}/, c)
    gsub(/\{\{SCOPE_BOUNDARY\}\}/, s)
    print
  }' "$TEMPLATE")
else
  PROMPT="$QUERY"
fi

# Forward godspeed posture through xask prompt text.
# xbreed-ask paths already load SKILL.md via --with; this closes the gap for
# codex-exec paths (spark/direct) where no skill mechanism exists.
if [ "$SKILL" = "godspeed" ]; then
  PROMPT="$PROMPT | godspeed"
fi

# Debug mode
if [ "$DEBUG" = true ]; then
  echo "=== XASK DEBUG ==="
  echo "MODEL: $MODEL"
  echo "MODE: $([ "$RICH" = true ] && echo RICH || echo CLEAN)$([ "$DIRECT" = true ] && echo '+DIRECT')"
  echo "SCOPE: $SCOPE"
  echo "SKILL: $SKILL"
  echo "TEMPLATE: $TEMPLATE"
  echo "CONSTRUCTED PROMPT ($(echo "$PROMPT" | wc -c) bytes):"
  echo "---"
  echo "$PROMPT"
  echo "---"
  exit 0
fi

# --- Gemini rich mode: PID-namespaced settings copy to avoid race ---
# Concurrent xask --rich calls no longer stomp each other's state.
# Instead of mutating the shared settings.json, we copy it to a temp file,
# mutate the copy, point HOME at the temp dir, and clean up on exit.
RICH_TMPDIR=""
gemini_rich_setup() {
  RICH_TMPDIR=$(mktemp -d "/tmp/xask-rich-$$-XXXXXX")
  mkdir -p "$RICH_TMPDIR/.gemini"
  if [ -f "$GEMINI_SETTINGS_FILE" ]; then
    cp "$GEMINI_SETTINGS_FILE" "$RICH_TMPDIR/.gemini/settings.json"
  else
    echo '{}' > "$RICH_TMPDIR/.gemini/settings.json"
  fi
  # Copy OAuth creds so auth still works from the temp HOME
  if [ -f "$HOME/.gemini/oauth_creds.json" ]; then
    cp "$HOME/.gemini/oauth_creds.json" "$RICH_TMPDIR/.gemini/oauth_creds.json"
  fi
  # Preserve named OAuth profiles so gemini_profiles_root() resolves correctly
  if [ -d "$HOME/.config/xbreed/gemini-profiles" ]; then
    mkdir -p "$RICH_TMPDIR/.config/xbreed"
    ln -s "$HOME/.config/xbreed/gemini-profiles" "$RICH_TMPDIR/.config/xbreed/gemini-profiles"
  fi
  python3 -c "
import json, sys
with open('$RICH_TMPDIR/.gemini/settings.json') as f: d = json.load(f)
d.setdefault('context', {})['includeDirectoryTree'] = True
with open('$RICH_TMPDIR/.gemini/settings.json', 'w') as f: json.dump(d, f, indent=2)
" || { echo "xask: failed to set up rich mode" >&2; rm -rf "$RICH_TMPDIR"; return 1; }
}
gemini_rich_cleanup() {
  [ -n "$RICH_TMPDIR" ] && rm -rf "$RICH_TMPDIR"
}

# Dispatch — contamination-aware per model
case "$MODEL" in
  gemini)
    if [ "$RICH" = true ]; then
      gemini_rich_setup || exit 1
      trap 'gemini_rich_cleanup' EXIT
      export HOME="$RICH_TMPDIR"
    fi
    EFFORT_FLAG=""
    [ -n "$EFFORT" ] && EFFORT_FLAG="--effort $EFFORT"
    xbreed ask gemini --with "$SKILL" ${EFFORT_FLAG:+$EFFORT_FLAG} "$PROMPT"
    ;;
  codex)
    SPARK_FLAG=""
    [ "$SPARK" = true ] && SPARK_FLAG="--spark"
    EFFORT_FLAG=""
    [ -n "$EFFORT" ] && EFFORT_FLAG="--effort $EFFORT"
    xbreed ask codex --with "$SKILL" ${SPARK_FLAG:+$SPARK_FLAG} ${EFFORT_FLAG:+$EFFORT_FLAG} "$PROMPT"
    ;;
  claude)
    EFFORT_FLAG=""
    [ -n "$EFFORT" ] && EFFORT_FLAG="--effort $EFFORT"
    xbreed ask claude --with "$SKILL" ${EFFORT_FLAG:+$EFFORT_FLAG} "$PROMPT"
    ;;
  *)
    echo "Unknown model: $MODEL. Use gemini, codex, or claude." >&2
    exit 1
    ;;
esac
