#!/bin/bash
# xask — minimal routing protocol for cross-model orchestration
# Usage: xask [-d] [-scp <scope>] [-r] [--spk] [-R] [-F] [--gpt55] [--gs] [-e <level>] [-o <file>] [--json] <model> "<query>" ["<context>"] ["<skill>"]
#
# All dispatches route through `xbreed ask`. Always-on: suppression, approval bypass,
# auth cascade, godspeed forwarding, fast_mode (gpt-5.4 family). See docs/xask-protocol.md.
#
# Always-on codex exec flags (applied by src/ask.rs, not user-togglable here):
#   --skip-git-repo-check · --color never · --ephemeral · --sandbox danger-full-access
#   -c approval_policy="never" · -c include_permissions_instructions=false
#   -c include_apps_instructions=false · -c include_environment_context=false
#
# Flags: -d (debug) | -scp (scope; was -s, renamed 2026-04-24 — -s conflicted)
#      | -r (rich) | --spk (spark) | -R (review) | -F (full) | --gpt55 (gpt-5.5)
#      | --gs (explicit godspeed SKILL load) | -e (effort) | -o (output-last-message) | --json
#
# codex model lanes:
#   default:       gpt-5.4-mini + fast_mode + reasoning=high (user directive 2026-04-17)
#   --spark:       gpt-5.3-codex-spark + reasoning=low (labrat probes)
#   --review / -R: gpt-5.4-mini + fast_mode (reviewer/critic/sentinel default per 2026-04-18)
#   -R --full/-F:  gpt-5.4 full + fast_mode (the-revenger RECON escape hatch, 1.05M ctx)
#   --gpt55:       gpt-5.5 + fast_mode (xbrd-exec bench xask-arm measurement, 2026-04-24)
#
# Examples:
#   xask gemini "What patterns exist?"              # clean, godspeed loaded (default SKILL)
#   xask --gs gemini "What patterns exist?"         # explicit godspeed load (SKILL override)
#   xask -scp "src/ask.rs" gemini "Review this"     # scoped clean dispatch
#   xask -r gemini "Explore the codebase"           # full context, dir tree ON
#   xask --spk codex "Probe this hypothesis"        # fast codex-spark, low effort
#   xask -R codex "Adversarial review of <diff>"    # review lane — gpt-5.4-mini
#   xask -R -F codex "RECON codebase-scale"         # -R + -F escape hatch — full gpt-5.4 (1.05M ctx)
#   xask --gpt55 --gs -e high codex "Deep question" # gpt-5.5 lane, explicit godspeed, high effort
#   xask -e high codex "Deep question"              # explicit reasoning effort
# PATH self-heal: agent-spawned non-login non-interactive shells get the minimal
# default PATH and miss ~/.local/bin, where xbreed (called by bare name below) lives.
# Real script dir first (readlink -f dereferences the /usr/local/bin shim symlink).
_XASK_DIR="$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")"
case ":$PATH:" in *":$_XASK_DIR:"*) ;; *) PATH="$_XASK_DIR:$PATH" ;; esac
case ":$PATH:" in *":$HOME/.local/bin:"*) ;; *) PATH="$HOME/.local/bin:$PATH" ;; esac
export PATH

GEMINI_SETTINGS_FILE="$HOME/.gemini/settings.json"

# Handle flags
DEBUG=false
SCOPE="entire project"
RICH=false
SPARK=false
REVIEW=false
FULL=false
GPT55=false
FORCE_GS=false
EFFORT=""
OUTPUT_LAST_MESSAGE=""
EFFORT_FLAGS=()
SPARK_FLAGS=()
REVIEW_FLAGS=()
FULL_FLAGS=()
GPT55_FLAGS=()
OUTPUT_FLAGS=()
JSON_FLAGS=()
while [[ "$1" == -* ]]; do
  case "$1" in
    --debug  | -d)   DEBUG=true; shift ;;
    --scope  | -scp) SCOPE="$2"; shift 2 ;;
    --rich   | -r)   RICH=true; shift ;;
    --spark  | --spk) SPARK=true; shift ;;
    --review | -R)   REVIEW=true; shift ;;
    --full   | -F)   FULL=true; shift ;;
    --gpt55) GPT55=true; shift ;;
    --gs) FORCE_GS=true; shift ;;
    --effort | -e)   EFFORT="$2"; shift 2 ;;
    --output-last-message | -o) OUTPUT_LAST_MESSAGE="$2"; shift 2 ;;
    --json) JSON=true; shift ;;
    *) echo "xask: unknown flag '$1' (valid: -d|--debug, -scp|--scope, -r|--rich, --spk|--spark, -R|--review, -F|--full, --gpt55, --gs, -e|--effort, -o|--output-last-message, --json)" >&2; exit 1 ;;
  esac
done

if [ -n "$EFFORT" ]; then
  case "$EFFORT" in
    low|medium|high|xhigh) ;;
    *) echo "xask: invalid effort level '$EFFORT' (use low|medium|high|xhigh)" >&2; exit 1 ;;
  esac
fi
[ -n "$EFFORT" ] && EFFORT_FLAGS=(--effort "$EFFORT")
[ "$SPARK" = true ] && SPARK_FLAGS=(--spark)
[ "$REVIEW" = true ] && REVIEW_FLAGS=(--review)
[ "$FULL" = true ] && FULL_FLAGS=(--full)
[ "$GPT55" = true ] && GPT55_FLAGS=(--gpt55)
[ -n "$OUTPUT_LAST_MESSAGE" ] && OUTPUT_FLAGS=(--output-last-message "$OUTPUT_LAST_MESSAGE")
[ "$JSON" = true ] && JSON_FLAGS=(--json)

MODEL="$1"
QUERY="$2"
CONTEXT="${3:-No prior context.}"
SKILL="${4:-godspeed}"

# --gs forces SKILL=godspeed regardless of the 4th positional (explicit load
# through our xask <skill> dispatch — idempotent with the default since SKILL
# already defaults to "godspeed", but makes intent visible and overrides any
# non-default positional). Added 2026-04-24 after user request.
if [ "$FORCE_GS" = true ]; then
  SKILL="godspeed"
fi

# Validate MODEL before template construction to prevent path traversal
# (previously: `xask -d ../../docs/xask-protocol probe` would exfil docs via
# debug-mode early exit at line ~99). Whitelist approach — matches the
# dispatch case statement below.
case "$MODEL" in
  gemini|codex) ;;
  *) echo "xask: unknown model '$MODEL'. Use gemini or codex." >&2; exit 1 ;;
esac

# Real dir, not the invoked path — /usr/local/bin holds a shim symlink to this
# script, and TEMPLATE_DIR below is relative to the real install location.
SCRIPT_DIR="$_XASK_DIR"
# Dispatch-template dir. templates/ was briefly removed 2026-04-17 but restored
# the same day — dispatch substitution (gemini {{THINKING_BUDGET}} injection) is
# load-bearing for multi-level effort routing, and xask's raw-$QUERY fallback
# drops that behavior silently. Override via XBREED_DISPATCH_DIR if needed.
TEMPLATE_DIR="${XBREED_DISPATCH_DIR:-$SCRIPT_DIR/../templates/dispatch}"
TEMPLATE="$TEMPLATE_DIR/${MODEL}.md"

if [ -z "$MODEL" ] || [ -z "$QUERY" ]; then
  echo "Usage: xask [-d|--debug] [-scp|--scope <scope>] [-r|--rich] [--spk|--spark] [-R|--review] [-F|--full] [-e|--effort <level>] [-o|--output-last-message <FILE>] [--json] <model> \"<query>\" [\"<context>\"] [\"<skill>\"]" >&2
  exit 1
fi

# Build prompt from template
if [ -f "$TEMPLATE" ]; then
  # Escape & and \ in replacement strings to prevent awk gsub from
  # interpreting & as "matched text" and \ as escape sequences.
  QUERY_SAFE=$(printf '%s' "$QUERY" | sed 's/[&\\]/\\&/g')
  CONTEXT_SAFE=$(printf '%s' "$CONTEXT" | sed 's/[&\\]/\\&/g')
  SCOPE_SAFE=$(printf '%s' "$SCOPE" | sed 's/[&\\]/\\&/g')
  EFFORT_SAFE=$(printf '%s' "${EFFORT:-unset}" | sed 's/[&\\]/\\&/g')
  # Map abstract effort tier → numeric thinkingBudget. Only gemini's dispatch
  # template substitutes this — gemini-CLI has no native --effort flag, so the
  # budget is injected as prompt-text directive. codex template doesn't
  # reference {{THINKING_BUDGET}}, so substitution is a no-op there.
  case "${EFFORT:-}" in
    low)    THINKING_BUDGET="512" ;;
    medium) THINKING_BUDGET="4096" ;;
    high)   THINKING_BUDGET="8192" ;;
    xhigh)  THINKING_BUDGET="16384" ;;
    *)      THINKING_BUDGET="default" ;;
  esac
  THINKING_BUDGET_SAFE=$(printf '%s' "$THINKING_BUDGET" | sed 's/[&\\]/\\&/g')
  PROMPT=$(awk -v q="$QUERY_SAFE" -v c="$CONTEXT_SAFE" -v s="$SCOPE_SAFE" -v e="$EFFORT_SAFE" -v t="$THINKING_BUDGET_SAFE" '{
    gsub(/\{\{QUERY\}\}/, q)
    gsub(/\{\{CONTEXT\}\}/, c)
    gsub(/\{\{SCOPE_BOUNDARY\}\}/, s)
    gsub(/\{\{EFFORT\}\}/, e)
    gsub(/\{\{THINKING_BUDGET\}\}/, t)
    print
  }' "$TEMPLATE")
else
  # Fail loud — silent raw-$QUERY fallback masked the xask-gate-regress-0420
  # install regression (templates/dispatch was not synced into ~/.local by
  # `make install` → xask collapsed to 16-byte raw prompt, stripping the
  # Inter-Model Protocol envelope + {{THINKING_BUDGET}} substitution + scope
  # framing). Invariant-preservation: degraded envelope must never ship
  # invisibly.
  echo "xask: dispatch template not found at $TEMPLATE" >&2
  echo "xask: templates must be at \$XBREED_DISPATCH_DIR or \$SCRIPT_DIR/../templates/dispatch" >&2
  echo "xask: run 'make install' from the xbreed repo to sync dispatch templates" >&2
  exit 1
fi

# Forward godspeed posture through xask prompt text.
# xbreed-ask paths already load SKILL.md via --with; this closes the gap for
# codex-exec paths (spark/direct) where no skill mechanism exists.
if [ "$SKILL" = "godspeed" ]; then
  PROMPT="$PROMPT | godspeed"
fi

# Debug mode
if [ "$DEBUG" = true ]; then
  echo "=== XASK DEBUG ==="
  echo "MODEL: $MODEL"
  echo "MODE: $([ "$RICH" = true ] && echo RICH || echo CLEAN)"
  echo "SPARK: $SPARK"
  echo "REVIEW: $REVIEW"
  echo "EFFORT: ${EFFORT:-<unset>}"
  echo "SCOPE: $SCOPE"
  echo "SKILL: $SKILL"
  echo "TEMPLATE: $TEMPLATE"
  echo "CONSTRUCTED PROMPT ($(echo "$PROMPT" | wc -c) bytes):"
  echo "---"
  echo "$PROMPT"
  echo "---"
  exit 0
fi

# --- Gemini rich mode: PID-namespaced settings copy to avoid race ---
# Concurrent xask --rich calls no longer stomp each other's state.
# Instead of mutating the shared settings.json, we copy it to a temp file,
# mutate the copy, point HOME at the temp dir, and clean up on exit.
XASK_RICH_ROOT="${XDG_CACHE_HOME:-$HOME/.cache}/xbreed/xask-rich"
[[ "$XASK_RICH_ROOT" != /* ]] && XASK_RICH_ROOT="$HOME/.cache/xbreed/xask-rich"
RICH_TMPDIR=""
gemini_rich_setup() {
  mkdir -p "$XASK_RICH_ROOT"
  chmod 700 "$XASK_RICH_ROOT"
  # Sweep stale dirs older than 60 minutes (covers SIGKILL/OOM orphans)
  # fire-and-forget intentional: stale-dir sweep; failure must not block rich-mode setup
  find "$XASK_RICH_ROOT" -maxdepth 1 -name 'xask-rich-*' -mmin +60 -exec rm -rf {} + 2>/dev/null || true
  RICH_TMPDIR=$(mktemp -d "$XASK_RICH_ROOT/xask-rich-$$-XXXXXX")
  mkdir -p "$RICH_TMPDIR/.gemini"
  if [ -f "$GEMINI_SETTINGS_FILE" ]; then
    cp "$GEMINI_SETTINGS_FILE" "$RICH_TMPDIR/.gemini/settings.json"
  else
    echo '{}' > "$RICH_TMPDIR/.gemini/settings.json"
  fi
  # Copy OAuth creds so auth still works from the temp HOME
  if [ -f "$HOME/.gemini/oauth_creds.json" ]; then
    cp "$HOME/.gemini/oauth_creds.json" "$RICH_TMPDIR/.gemini/oauth_creds.json"
  fi
  XASK_RICH_SETTINGS="$RICH_TMPDIR/.gemini/settings.json" python3 -c "
import json, os
f = os.environ['XASK_RICH_SETTINGS']
with open(f) as fh: d = json.load(fh)
d.setdefault('context', {})['includeDirectoryTree'] = True
with open(f, 'w') as fh: json.dump(d, fh, indent=2)
" || { echo "xask: failed to set up rich mode" >&2; rm -rf "$RICH_TMPDIR"; return 1; }
}
gemini_rich_cleanup() {
  [ -n "$RICH_TMPDIR" ] && rm -rf "$RICH_TMPDIR"
}

t_start_s=$(date +%s.%N)

# Dispatch — contamination-aware per model
case "$MODEL" in
  gemini)
    if [ "$RICH" = true ]; then
      gemini_rich_setup || exit 1
      trap 'gemini_rich_cleanup' EXIT INT TERM HUP
      export HOME="$RICH_TMPDIR"
    fi
    xbreed ask gemini --with "$SKILL" "${EFFORT_FLAGS[@]}" "$PROMPT"
    ;;
  codex)
    xbreed ask codex --with "$SKILL" "${SPARK_FLAGS[@]}" "${REVIEW_FLAGS[@]}" "${FULL_FLAGS[@]}" "${GPT55_FLAGS[@]}" "${EFFORT_FLAGS[@]}" "${OUTPUT_FLAGS[@]}" "${JSON_FLAGS[@]}" "$PROMPT"
    ;;
  *)
    echo "Unknown model: $MODEL. Use gemini or codex." >&2
    exit 1
    ;;
esac
RC=$?

if [ -n "${XBREED_BENCH_LOG:-}" ]; then
  t_end_s=$(date +%s.%N)
  wall_s=$(awk -v s="$t_start_s" -v e="$t_end_s" 'BEGIN{printf "%.3f", e - s}')
  t_complete_iso=$(date -Iseconds)
  printf '{"t_complete_iso":"%s","cli":"%s","wall_s":%s,"exit_code":%d,"effort":"%s","teammate":"%s"}\n' \
    "$t_complete_iso" "$MODEL" "$wall_s" "$RC" "${EFFORT:-default}" "${XBREED_BENCH_TEAMMATE:-null}" \
    >> "$XBREED_BENCH_LOG"
fi

exit $RC
